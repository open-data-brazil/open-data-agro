{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "Comex export series must contain observations." }
    },
    {
      "type": "expect_column_to_exist",
      "kwargs": { "column": "co_ncm" },
      "meta": { "notes": "Official NCM code for traceability." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "data" },
      "meta": { "notes": "Month grain required." }
    },
    {
      "type": "expect_column_values_to_match_regex",
      "kwargs": { "column": "data", "regex": "^\\d{4}-\\d{2}-\\d{2}$" },
      "meta": { "notes": "Canonical ISO month date." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "valor_fob_usd" },
      "meta": { "notes": "FOB export value in USD." }
    },
    {
      "type": "expect_column_values_to_be_between",
      "kwargs": { "column": "valor_fob_usd", "min_value": 0, "mostly": 1.0 },
      "meta": { "notes": "FOB value must be non-negative." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "quantidade_kg" },
      "meta": { "notes": "Export quantity in kilograms." }
    },
    {
      "type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["co_ncm", "data"] },
      "meta": { "notes": "No duplicate observations per NCM/month." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "mdic.comex-exportacao-ncm-mes",
    "fonte_oficial": "https://comexstat.mdic.gov.br/",
    "agencia": "MDIC"
  },
  "name": "bronze.mdic.comex_exportacao_ncm_mes",
  "id": "bronze-mdic-comex-exportacao-ncm-mes-suite"
}
