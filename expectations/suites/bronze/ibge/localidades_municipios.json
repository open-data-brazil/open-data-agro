{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "Bronze partition must contain at least one municipality row." }
    },
    {
      "type": "expect_column_to_exist",
      "kwargs": { "column": "codigo_ibge" },
      "meta": { "notes": "Seven-digit IBGE municipality code." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "codigo_ibge" },
      "meta": { "notes": "Municipality code must be present." }
    },
    {
      "type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "codigo_ibge" },
      "meta": { "notes": "Each municipality appears once per snapshot." }
    },
    {
      "type": "expect_column_value_lengths_to_equal",
      "kwargs": { "column": "codigo_ibge", "value": 7 },
      "meta": { "notes": "IBGE municipality codes are seven digits." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "ibge.localidades-municipios",
