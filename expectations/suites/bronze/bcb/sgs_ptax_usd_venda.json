{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "PTAX sell series must contain observations." }
    },
    {
      "type": "expect_column_values_to_be_in_set",
      "kwargs": { "column": "sgs_codigo", "value_set": ["1"] },
      "meta": { "notes": "PTAX USD sell series code." }
    },
    {
      "type": "expect_column_values_to_match_regex",
      "kwargs": { "column": "data", "regex": "^\\d{4}-\\d{2}-\\d{2}$" },
      "meta": { "notes": "Canonical ISO date." }
    },
    {
      "type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["sgs_codigo", "data"] },
      "meta": { "notes": "No duplicate observations per series/date." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "bcb.sgs-ptax-usd-venda",
    "fonte_oficial": "https://dadosabertos.bcb.gov.br/",
    "agencia": "BCB"
  },
  "name": "bronze.bcb.sgs_ptax_usd_venda",
  "id": "bronze-bcb-sgs-ptax-usd-venda-suite"
}
