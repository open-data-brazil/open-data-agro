# Storage mode: local (default) | minio | r2
# local  — filesystem under LAKE_LOCAL_ROOT (no cloud credentials)
# minio  — S3-compatible API via Docker MinIO (Phase 2)
# r2     — Cloudflare R2 (production)
STORAGE_MODE=local

# Stack pins — see .local/STACK-VERSIONS.md
# PostgreSQL 18.4 | Redis 8.8.0 | Go 1.26.4 | DuckDB 1.5.4 | dbt-core 1.11.11 | GE 1.18.1

# PostgreSQL 18.4 (Docker Compose: postgres:18.4-bookworm)
# Primary keys use native uuidv7() — see infra/postgres/README.md
# POSTGRES_HOST_PORT defaults to 5432; override if the port is already in use locally
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://open_data_agro:open_data_agro@localhost:5432/open_data_agro

# Redis 8.8.0 (Docker Compose: redis:8.8.0-bookworm)
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Local lake root — bronze/silver/gold when STORAGE_MODE=local
LAKE_LOCAL_ROOT=./lake

# MinIO — local S3 substitute (STORAGE_MODE=minio; Phase 2 — build from source)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=open-data-agro

# Cloudflare R2 — production only (STORAGE_MODE=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=open-data-agro
R2_ENDPOINT=https://{account_id}.r2.cloudflarestorage.com

# DuckDB 1.5.4 analytics (file path or :memory:)
DUCKDB_PATH=./duckdb/open_data_agro.duckdb

# Delta Lake silver layer — delta-rs 1.6.0 via Python (local path by default)
DELTA_STORAGE_PATH=./lake/silver/
# Minimum Delta versions retained in dev (documented; log retention via table properties)
DELTA_MIN_VERSIONS=30

# Optional alert webhook (stub — logs only until wired)
ALERT_WEBHOOK_URL=
