{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "Comex export by UF series must contain observations." }
    },
    {
      "type": "expect_column_to_exist",
      "kwargs": { "column": "uf" },
      "meta": { "notes": "IBGE state sigla for geographic joins." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "data" },
      "meta": { "notes": "Month grain required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "valor_fob_usd" },
      "meta": { "notes": "FOB export value in USD." }
    },
    {
      "type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["co_ncm", "uf", "data"] },
      "meta": { "notes": "No duplicate observations per NCM/UF/month." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "mdic.comex-exportacao-uf-ncm",
    "fonte_oficial": "https://comexstat.mdic.gov.br/",
    "agencia": "MDIC"
  },
  "name": "bronze.mdic.comex_exportacao_uf_ncm",
  "id": "bronze-mdic-comex-exportacao-uf-ncm-suite"
}
