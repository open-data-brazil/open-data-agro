  create view "dbt_workspace"."main"."stg_aneel__tarifas_energia__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/data/dev/projects/webstorm/open-data-agro/lake/silver/aneel/tarifas_energia/**/*.parquet')

),

renamed as (
    select
        
    DatGeracaoConjuntoDados,
    DatCompetencia,
    NomBandeiraAcionada,
    VlrAdicionalBandeira
,
        cast(_ingested_at as varchar) as capturado_em,
        '
  https://dadosabertos.aneel.gov.br/dataset/bandeiras-tarifarias
' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by DatCompetencia, NomBandeiraAcionada
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
