{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "ONI seasonal rows must be present." }
    },
    {
      "type": "expect_column_to_exist",
      "kwargs": { "column": "refyear" },
      "meta": { "notes": "Season center year." }
    },
    {
      "type": "expect_column_to_exist",
      "kwargs": { "column": "season_code" },
      "meta": { "notes": "3-letter season code (DJF, JFM, …)." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "refyear" },
      "meta": { "notes": "Year required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "season_code" },
      "meta": { "notes": "Season required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "anomaly" },
      "meta": { "notes": "ONI anomaly required." }
    },
    {
      "type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["refyear", "season_code"] },
      "meta": { "notes": "One row per year × season." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "noaa.enso-indices",
    "fonte_oficial": "https://www.cpc.ncep.noaa.gov/products/analysis_monitoring/ensostuff/ONI_v5.php",
    "agencia": "NOAA CPC",
    "license": "NOAA CPC/NCEI — U.S. Government work (public domain)"
  },
  "name": "bronze.noaa.enso_indices",
  "id": "bronze-noaa-enso-indices-suite"
}
