  create view "dbt-test-fresh3"."main"."stg_conab__estimativa_graos__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/tmp/dbt-test-lake/silver/conab/estimativa_graos/**/*.parquet')

),

renamed as (
    select
        
  "Produto" as produto,
  "UF" as uf,
  "Safra" as safra,
  "Região" as regiao,
  "Produção (mil t)" as producao_mil_t
,
        cast(_ingested_at as varchar) as capturado_em,
        'https://portaldeinformacoes.conab.gov.br/download-arquivos.html' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by produto, uf, safra
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

