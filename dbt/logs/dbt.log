  read_parquet('/data/dev/projects/webstorm/open-data-agro/lake/silver/ibge/localidades_municipios/**/*.parquet')

),

renamed as (
    select
        
    codigo_ibge,
    nome,
    sigla_uf,
    codigo_uf,
    codigo_regiao,
    nome_regiao
,
        cast(_ingested_at as varchar) as capturado_em,
        '
  https://servicodados.ibge.gov.br/api/docs/localidades
' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by codigo_ibge
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

