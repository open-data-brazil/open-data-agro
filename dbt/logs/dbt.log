  create view "dbt_workspace"."main"."stg_fao__food_price_index__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/tmp/international-sources-wave-3-ci-lake/silver/fao/food_price_index/**/*.parquet')

),

renamed as (
    select
        
    refmonth,
    index_slug,
    index_name,
    value,
    base_period
,
        cast(_ingested_at as varchar) as capturado_em,
        '
  https://www.fao.org/worldfoodsituation/foodpricesindex/en/
' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by index_slug, refmonth
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

