{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "Pink Sheet monthly prices must contain rows." }
    },
    {
      "type": "expect_column_to_exist",
      "kwargs": { "column": "refmonth" },
      "meta": { "notes": "Monthly period YYYY-MM." }
    },
    {
      "type": "expect_column_to_exist",
      "kwargs": { "column": "commodity_slug" },
      "meta": { "notes": "Canonical slug soja/milho/trigo/petroleo/carne_bovina." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "refmonth" },
      "meta": { "notes": "Month required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "series_name" },
      "meta": { "notes": "Pink Sheet series required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "value" },
      "meta": { "notes": "Price value required." }
    },
    {
      "type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["refmonth", "series_name"] },
      "meta": { "notes": "One row per month × series." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "worldbank.pink-sheet-monthly",
    "fonte_oficial": "https://www.worldbank.org/en/research/commodity-markets",
    "agencia": "World Bank",
    "license": "World Bank Open Data — CC BY 4.0"
  },
  "name": "bronze.worldbank.pink_sheet_monthly",
  "id": "bronze-worldbank-pink-sheet-monthly-suite"
}
