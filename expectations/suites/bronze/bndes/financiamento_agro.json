{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "BNDES CNAE disbursements must contain rows." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "ano" },
      "meta": { "notes": "Year required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "mes" },
      "meta": { "notes": "Month required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "agropecuaria" },
      "meta": { "notes": "Agropecuaria disbursement column required." }
    },
    {
      "type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["ano", "mes"] },
      "meta": { "notes": "Monthly CNAE sector grain." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "bndes.financiamento-agro",
