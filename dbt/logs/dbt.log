  create view "dbt_workspace"."main"."stg_inmet__estacoes_convencionais__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/tmp/macro-collection-ci-lake/silver/inmet/estacoes_convencionais/**/*.parquet')

),

renamed as (
    select
        
  trim(cd_estacao) as cd_estacao,
  trim(nome) as nome,
  cast(latitude as varchar) as latitude,
  cast(longitude as varchar) as longitude,
  trim(uf) as uf,
  trim(situacao) as situacao,
  trim(regiao) as regiao,
  cast(altitude as varchar) as altitude
,
        cast(_ingested_at as varchar) as capturado_em,
        '
  https://portal.inmet.gov.br/
' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by cd_estacao
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

