  create view "dbt_workspace"."main"."stg_ibge__pam_estabelecimentos__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/tmp/collection-pam-lake/silver/ibge/pam_estabelecimentos/**/*.parquet')

),

renamed as (
    select
        
    
    sidra_tabela,
    codigo_ibge,
    municipio,
    ano,
    variavel_codigo,
    variavel,
    produto_codigo,
    produto,
    valor,
    unidade_codigo,
    unidade

,
        cast(_ingested_at as varchar) as capturado_em,
        '
  https://sidra.ibge.gov.br/pesquisa/pam
' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by codigo_ibge, ano, variavel_codigo, produto_codigo
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

