    with silver as (
    select * from 
  read_parquet('/tmp/macro-collection-ci-lake/silver/bcb/sgs_igpm/**/*.parquet')

),

renamed as (
    select
        
    sgs_codigo,
    data,
    valor,
    ano
,
        cast(_ingested_at as varchar) as capturado_em,
        '
  https://dadosabertos.bcb.gov.br/
' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

