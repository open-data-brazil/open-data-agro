  create view "dbt_workspace"."main"."stg_conab__serie_historica_graos__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/tmp/open-data-agro-lake/silver/conab/serie_historica_graos/**/*.parquet')

),

renamed as (
    select
        
  trim(produto) as produto,
  trim(uf) as uf,
  trim(ano_agricola) as ano,
  cast(area_plantada_mil_ha as varchar) as area_plantada_mil_ha,
  cast(producao_mil_t as varchar) as producao_mil_t
,
        cast(_ingested_at as varchar) as capturado_em,
        'https://portaldeinformacoes.conab.gov.br/download-arquivos.html' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by produto, uf, ano
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
