  create view "dbt_workspace"."main"."stg_conab__alimenta_brasil_entregas__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/tmp/agricultura-familiar-mvp/silver/conab/alimenta_brasil_entregas/**/*.parquet')

),

renamed as (
    select
        
  cast(ano_entrega as varchar) as ano_entrega,
  cast(mes_entrega as varchar) as mes_entrega,
  trim(municipio) as municipio,
  trim(uf) as uf,
  trim(regiao) as regiao,
  trim(sexo) as sexo,
  trim(ds_unidade_medida) as unidade_medida,
  cast(qtd_entregue as varchar) as qtd_entregue,
  cast(valor_entregue as varchar) as valor_entregue
,
        cast(_ingested_at as varchar) as capturado_em,
        'https://portaldeinformacoes.conab.gov.br/download-arquivos.html' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by ano_entrega, mes_entrega, municipio, uf, sexo
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

