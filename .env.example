# PostgreSQL operational database
# POSTGRES_HOST_PORT defaults to 5432; override if the port is already in use locally
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://open_data_agro:open_data_agro@localhost:5432/open_data_agro

# Cloudflare R2 (S3-compatible lake storage)
# Optional local substitute: MinIO — see docs/OFFICIAL-SOURCES.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=open-data-agro
R2_ENDPOINT=https://{account_id}.r2.cloudflarestorage.com

# DuckDB analytics (file path or :memory:)
DUCKDB_PATH=./duckdb/analytics.duckdb

# Delta Lake storage (s3://{bucket}/silver/ or local path for dev)
# Evaluate delta-rs (https://delta-io.github.io/delta-rs/) for Node path
DELTA_STORAGE_PATH=./lake/silver/
