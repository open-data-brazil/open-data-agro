  trim(dsc_nivel_comercializacao) as nivel_comercializacao,
  cast(valor_produto_kg as varchar) as valor_produto_kg
,
        cast(_ingested_at as varchar) as capturado_em,
        'https://portaldeinformacoes.conab.gov.br/download-arquivos.html' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by produto, id_produto, cod_ibge, ano, mes, nivel_comercializacao
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

