{
  "expectations": [
    {
      "type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1 },
      "meta": { "notes": "PEVS annual series must contain observations." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "codigo_uf" },
      "meta": { "notes": "UF code required." }
    },
    {
      "type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "ano" },
      "meta": { "notes": "Annual period required." }
    },
    {
      "type": "expect_column_values_to_be_in_set",
      "kwargs": { "column": "sidra_tabela", "value_set": ["289"] },
      "meta": { "notes": "PEVS UF series uses SIDRA table 289." }
    },
    {
      "type": "expect_compound_columns_to_be_unique",
      "kwargs": { "column_list": ["codigo_uf", "ano", "variavel_codigo", "produto_codigo"] },
      "meta": { "notes": "UF annual plant extraction grain." }
    }
  ],
  "meta": {
    "great_expectations_version": "1.18.1",
    "dataset_id": "ibge.pevs-producao-vegetal",
    "fonte_oficial": "https://sidra.ibge.gov.br/pesquisa/pevs",
    "agencia": "IBGE"
  },
  "name": "bronze.ibge.pevs_producao_vegetal",
  "id": "bronze-ibge-pevs-producao-vegetal-suite"
}
