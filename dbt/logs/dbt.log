  create view "dbt_workspace"."main"."stg_conab__capacidade_estatica__dbt_tmp" as (
    with silver as (
    select * from 
  read_parquet('/tmp/p1-collection-ci-lake/silver/conab/serie_historica_capacidade_estatica/**/*.parquet')

),

renamed as (
    select
        
  cast("Ano" as varchar) as ano,
  trim("UF") as uf,
  cast("Quantidade (mil t)" as varchar) as quantidade_mil_t
,
        cast(_ingested_at as varchar) as capturado_em,
        'https://portaldeinformacoes.conab.gov.br/download-arquivos.html' as fonte_oficial,
        _dataset_id,
        _source_file
    from silver
)

select * exclude (rn)
from (
    select
        *,
        row_number() over (
            partition by ano, uf
            order by capturado_em desc, _source_file desc
        ) as rn
    from renamed
)
where rn = 1
  );

